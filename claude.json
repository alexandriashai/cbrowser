{
  "name": "cbrowser",
  "version": "18.14.1",
  "description": "Cognitive browser automation with 90+ MCP tools for AI agents. Simulate real user cognition, run persona-based testing, and make sites AI-friendly.",
  "mcp": {
    "transport": "stdio",
    "command": "node",
    "args": ["dist/mcp-server.js"]
  },
  "tools": 91,
  "categories": [
    "browser-automation",
    "testing",
    "accessibility",
    "cognitive",
    "ai-agents"
  ],
  "features": [
    "17 cognitive personas",
    "25-trait cognitive model",
    "Visual regression testing",
    "Self-healing selectors",
    "Chaos engineering",
    "Empathy audits",
    "AI-friendliness grading"
  ],
  "requirements": {
    "node": ">=18.0.0",
    "playwright": "chromium browser will be installed automatically"
  },
  "author": {
    "name": "Alexandria Eden",
    "email": "alexandria.shai.eden@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://cbrowser.ai",
  "repository": "https://github.com/alexandriashai/cbrowser",
  "documentation": "https://cbrowser.ai/docs"
}
